# Optional. The dashboard works without any keys (it ships with a cached data
# snapshot and a cached AI analysis). Keys unlock live regeneration.

# Anthropic API key — powers the AI Analyst "Regenerate" button.
# The analyst uses Claude's server-side web search tool for live research,
# so this single key covers both the LLM and the web research.
ANTHROPIC_API_KEY=

# Optional. FRED API key (https://fred.stlouisfed.org/docs/api/api_key.html).
# Only used by scripts/fetch-data.mjs for US context series (10Y yield, US CPI).
# Everything else (IMF WEO, World Bank, open FX) needs no key.
FRED_API_KEY=
